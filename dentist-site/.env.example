# .env.example — скопируй в .env и заполни реальными значениями
# Файл .env НЕ заливается на GitHub (он в .gitignore)

# Токен бота — получить у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Твой личный chat_id — бот будет слать тебе уведомления об отзывах
# Узнать свой id: написать @userinfobot в Telegram
DOCTOR_CHAT_ID=your_chat_id_here

# Ссылка на твой TG-канал
CHANNEL_URL=https://t.me/Artur_Kompanets11
